    "class": "#8762c6",
    "class.declaration": "#8762c6",
    "struct": "#8762c6",
    "interface": "#8762c6",
    "enum": "#009c8f",
    "enumMember": "#c25d1e",
    "namespace": "#8762c6",
    "typeParameter": "#009c8f",
    "parameter": { "foreground": "#c25d1e", "italic": true },
    "variable": "#3a2f22",
    "variable.readonly": "#c25d1e",
    "variable.defaultLibrary": { "foreground": "#c25d1e", "italic": true },
    "property": "#0072d4",
    "property.declaration": "#0072d4",
    "property.readonly": "#c25d1e",
    "macro": "#ca4898",
    "decorator": "#ca4898",
    "label": "#ad8900",
    "keyword": "#d2212d",
    "comment": { "foreground": "#8a7f6f", "italic": true },
    "string": "#489100",
    "regexp": "#ca4898",
    "number": "#009c8f",
    "selfKeyword": { "foreground": "#c25d1e", "italic": true },
    "builtinType": { "foreground": "#8762c6", "italic": true }
