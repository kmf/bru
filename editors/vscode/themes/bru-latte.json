  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8a7f6f", "fontStyle": "italic" }
    },
    {
      "scope": ["comment.block.documentation", "comment.block.javadoc"],
      "settings": { "foreground": "#61574b", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#489100" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#009c8f" }
    },
    {
      "scope": ["constant.language"],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["constant.other", "variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["variable"],
      "settings": { "foreground": "#3a2f22" }
    },
    {
      "scope": ["variable.language"],
      "settings": { "foreground": "#c25d1e", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#c25d1e", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.other.property", "support.type.property-name", "meta.object-literal.key"],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#d2212d" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": { "foreground": "#3a2f22" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#8762c6" }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#8762c6" }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#815cc0" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#d2212d" }
    },
    {
      "scope": ["entity.name.tag.css"],
      "settings": { "foreground": "#ad8900" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#ad8900" }
    },
    {
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["support.constant"],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["meta.preprocessor", "keyword.control.directive", "keyword.control.import"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#3a2f22" }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#8a7f6f" }
    },
    {
      "scope": ["punctuation.section.embedded"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": { "foreground": "#3a2f22" }
    },
    {
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#ad8900" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#ad8900", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.strikethrough"],
      "settings": { "fontStyle": "strikethrough" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code", "markup.raw"],
      "settings": { "foreground": "#489100" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#489100" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#d2212d" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#ad8900" }
    },
    {
      "scope": ["markup.list.numbered", "markup.list.unnumbered"],
      "settings": { "foreground": "#d2212d" }
    },
    {
      "scope": ["markup.quote"],
      "settings": { "foreground": "#8a7f6f", "fontStyle": "italic" }
    },
    {
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name.css"],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": ["support.constant.property-value.css", "support.constant.color.css"],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["constant.other.color.rgb-value.hex.css"],
      "settings": { "foreground": "#009c8f" }
    },
    {
      "scope": ["source.css keyword.other.unit"],
      "settings": { "foreground": "#009c8f" }
    },
    {
      "scope": [
        "source.yaml entity.name.tag",
        "source.yaml punctuation.definition.key"
      ],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": ["source.json support.type.property-name"],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": ["entity.name.type.enum"],
      "settings": { "foreground": "#009c8f" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#0072d4",
