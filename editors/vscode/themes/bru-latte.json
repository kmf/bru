    "icon.foreground": "#8a7f6f",
    "selection.background": "#ece3cc",
    "widget.shadow": "#faf3e080"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8a7f6f", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#489100" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#009c8f" }
    },
    {
      "scope": ["constant.language"],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["constant.other"],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["variable"],
      "settings": { "foreground": "#3a2f22" }
    },
    {
      "scope": ["variable.language"],
      "settings": { "foreground": "#c25d1e", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#c25d1e", "fontStyle": "italic" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#d2212d" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": { "foreground": "#3a2f22" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#8762c6" }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#8762c6" }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#815cc0" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#d2212d" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#ad8900" }
    },
    {
      "scope": [
        "support.constant",
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": { "foreground": "#c25d1e" }
    },
    {
      "scope": ["meta.preprocessor", "keyword.control.directive"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#3a2f22" }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#8a7f6f" }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#ca4898" }
    },
    {
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#ad8900" }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": { "foreground": "#ad8900", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#489100" }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#0072d4" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#489100" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#d2212d" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#ad8900" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#0072d4",
    "method": "#0072d4",
    "type": "#8762c6",
    "class": "#8762c6",
    "struct": "#8762c6",
    "interface": "#8762c6",
    "enum": "#8762c6",
    "enumMember": "#c25d1e",
    "namespace": "#8762c6",
    "parameter": { "foreground": "#c25d1e", "italic": true },
    "variable": "#3a2f22",
    "property": "#3a2f22",
    "macro": "#ca4898",
    "decorator": "#ca4898",
    "keyword": "#d2212d",
    "comment": { "foreground": "#8a7f6f", "italic": true },
    "string": "#489100",
    "number": "#009c8f"
  }
}
