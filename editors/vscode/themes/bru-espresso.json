    "icon.foreground": "#8a7f6f",
    "selection.background": "#322b23",
    "widget.shadow": "#1c181480"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#8a7f6f", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#75b938" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#f275be" }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#f275be" }
    },
    {
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#41c7b9" }
    },
    {
      "scope": ["constant.language"],
      "settings": { "foreground": "#ed8649" }
    },
    {
      "scope": ["constant.other"],
      "settings": { "foreground": "#ed8649" }
    },
    {
      "scope": ["variable"],
      "settings": { "foreground": "#f5e8c7" }
    },
    {
      "scope": ["variable.language"],
      "settings": { "foreground": "#ed8649", "fontStyle": "italic" }
    },
    {
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#ed8649", "fontStyle": "italic" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#fa5750" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment"],
      "settings": { "foreground": "#f5e8c7" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": { "foreground": "#4695f7" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#af88eb" }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#af88eb" }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": { "foreground": "#be9af5" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#fa5750" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#dbb32d" }
    },
    {
      "scope": [
        "support.constant",
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": { "foreground": "#ed8649" }
    },
    {
      "scope": ["meta.preprocessor", "keyword.control.directive"],
      "settings": { "foreground": "#f275be" }
    },
    {
      "scope": ["punctuation"],
      "settings": { "foreground": "#f5e8c7" }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#8a7f6f" }
    },
    {
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#f275be" }
    },
    {
      "scope": ["entity.name.label"],
      "settings": { "foreground": "#dbb32d" }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": { "foreground": "#dbb32d", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#75b938" }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#4695f7" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#75b938" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#fa5750" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#dbb32d" }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#4695f7",
    "method": "#4695f7",
    "type": "#af88eb",
    "class": "#af88eb",
    "struct": "#af88eb",
    "interface": "#af88eb",
    "enum": "#af88eb",
    "enumMember": "#ed8649",
    "namespace": "#af88eb",
    "parameter": { "foreground": "#ed8649", "italic": true },
    "variable": "#f5e8c7",
    "property": "#f5e8c7",
    "macro": "#f275be",
    "decorator": "#f275be",
    "keyword": "#fa5750",
    "comment": { "foreground": "#8a7f6f", "italic": true },
    "string": "#75b938",
    "number": "#41c7b9"
  }
}
