{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "espresso_bg":       "#1c1814",
    "espresso_bg_soft":  "#26211c",
    "espresso_bg_hi":    "#322b23",
    "espresso_border":   "#3a332b",
    "espresso_fg":       "#f5e8c7",
    "espresso_fg_alt":   "#fbf3db",
    "espresso_fg_muted": "#8a7f6f",
    "espresso_yellow":   "#dbb32d",
    "espresso_orange":   "#ed8649",
    "espresso_red":      "#fa5750",
    "espresso_magenta":  "#f275be",
    "espresso_violet":   "#af88eb",
    "espresso_blue":     "#4695f7",
    "espresso_teal":     "#41c7b9",
    "espresso_green":    "#75b938",

    "latte_bg":          "#faf3e0",
    "latte_bg_soft":     "#f3ead0",
    "latte_bg_hi":       "#ece3cc",
    "latte_border":      "#e0d4b0",
    "latte_fg":          "#3a2f22",
    "latte_fg_alt":      "#2d241a",
    "latte_fg_muted":    "#8a7f6f",
    "latte_yellow":      "#ad8900",
    "latte_orange":      "#c25d1e",
    "latte_red":         "#d2212d",
    "latte_magenta":     "#ca4898",
    "latte_violet":      "#8762c6",
    "latte_blue":        "#0072d4",
    "latte_teal":        "#009c8f",
    "latte_green":       "#489100",

    "diff_add_bg_dark":  "#1f2a1b",
    "diff_rem_bg_dark":  "#2e1f1d",
    "diff_add_bg_light": "#e8efd4",
    "diff_rem_bg_light": "#f3dcd8"
  },
  "theme": {
    "primary":         { "dark": "espresso_blue",    "light": "latte_blue" },
    "secondary":       { "dark": "espresso_violet",  "light": "latte_violet" },
    "accent":          { "dark": "espresso_yellow",  "light": "latte_yellow" },
    "error":           { "dark": "espresso_red",     "light": "latte_red" },
    "warning":         { "dark": "espresso_orange",  "light": "latte_orange" },
    "success":         { "dark": "espresso_green",   "light": "latte_green" },
    "info":            { "dark": "espresso_teal",    "light": "latte_teal" },

    "text":            { "dark": "espresso_fg",       "light": "latte_fg" },
    "textMuted":       { "dark": "espresso_fg_muted", "light": "latte_fg_muted" },

    "background":      { "dark": "espresso_bg",      "light": "latte_bg" },
    "backgroundPanel": { "dark": "espresso_bg_soft", "light": "latte_bg_soft" },
    "backgroundElement": { "dark": "espresso_bg_hi", "light": "latte_bg_hi" },

    "border":          { "dark": "espresso_border",  "light": "latte_border" },
    "borderActive":    { "dark": "espresso_yellow",  "light": "latte_yellow" },
    "borderSubtle":    { "dark": "espresso_border",  "light": "latte_border" },

    "diffAdded":              { "dark": "espresso_green", "light": "latte_green" },
    "diffRemoved":            { "dark": "espresso_red",   "light": "latte_red" },
    "diffContext":            { "dark": "espresso_fg_muted", "light": "latte_fg_muted" },
    "diffHunkHeader":         { "dark": "espresso_blue",  "light": "latte_blue" },
    "diffHighlightAdded":     { "dark": "espresso_green", "light": "latte_green" },
    "diffHighlightRemoved":   { "dark": "espresso_red",   "light": "latte_red" },
    "diffAddedBg":            { "dark": "diff_add_bg_dark", "light": "diff_add_bg_light" },
    "diffRemovedBg":          { "dark": "diff_rem_bg_dark", "light": "diff_rem_bg_light" },
    "diffContextBg":          { "dark": "espresso_bg_soft", "light": "latte_bg_soft" },
    "diffLineNumber":         { "dark": "espresso_fg_muted", "light": "latte_fg_muted" },
    "diffAddedLineNumberBg":  { "dark": "diff_add_bg_dark", "light": "diff_add_bg_light" },
    "diffRemovedLineNumberBg":{ "dark": "diff_rem_bg_dark", "light": "diff_rem_bg_light" },

    "markdownText":           { "dark": "espresso_fg",      "light": "latte_fg" },
    "markdownHeading":        { "dark": "espresso_yellow",  "light": "latte_yellow" },
    "markdownLink":           { "dark": "espresso_blue",    "light": "latte_blue" },
    "markdownLinkText":       { "dark": "espresso_teal",    "light": "latte_teal" },
    "markdownCode":           { "dark": "espresso_green",   "light": "latte_green" },
    "markdownBlockQuote":     { "dark": "espresso_fg_muted","light": "latte_fg_muted" },
    "markdownEmph":           { "dark": "espresso_orange",  "light": "latte_orange" },
    "markdownStrong":         { "dark": "espresso_violet",  "light": "latte_violet" },
    "markdownHorizontalRule": { "dark": "espresso_border",  "light": "latte_border" },
    "markdownListItem":       { "dark": "espresso_yellow",  "light": "latte_yellow" },
    "markdownListEnumeration":{ "dark": "espresso_teal",    "light": "latte_teal" },
    "markdownImage":          { "dark": "espresso_blue",    "light": "latte_blue" },
    "markdownImageText":      { "dark": "espresso_teal",    "light": "latte_teal" },
    "markdownCodeBlock":      { "dark": "espresso_fg",      "light": "latte_fg" },

    "syntaxComment":     { "dark": "espresso_fg_muted","light": "latte_fg_muted" },
    "syntaxKeyword":     { "dark": "espresso_red",     "light": "latte_red" },
    "syntaxFunction":    { "dark": "espresso_blue",    "light": "latte_blue" },
    "syntaxVariable":    { "dark": "espresso_fg",      "light": "latte_fg" },
    "syntaxString":      { "dark": "espresso_green",   "light": "latte_green" },
    "syntaxNumber":      { "dark": "espresso_teal",    "light": "latte_teal" },
    "syntaxType":        { "dark": "espresso_violet",  "light": "latte_violet" },
    "syntaxOperator":    { "dark": "espresso_fg",      "light": "latte_fg" },
    "syntaxPunctuation": { "dark": "espresso_fg",      "light": "latte_fg" }
  }
}
